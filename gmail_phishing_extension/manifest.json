{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "notifications",
    "storage"
  ],

  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "128": "icon.png"
  }
}