{
  "manifest_version": 3,
  "name": "AI Phishing Detector",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "notifications",
    "storage"
  ],

  "host_permissions": [
  "https://mail.google.com/*",
  "https://phishing-detection-1-8y6z.onrender.com/*"
],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"]
    }
  ],

  "icons": {
    "128": "icon.png"
  }
}